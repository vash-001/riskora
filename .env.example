# ============================================================
# RISKORA Backend — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000

# CORS — comma-separated list of allowed frontend origins
# In production: set to your actual domain(s)
# In development: leave as localhost
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,https://riskora.io

# Rust Logging Level
RUST_LOG=info

# Admin secret — used to protect /admin/* endpoints
# Generate a strong random value: openssl rand -hex 32
ADMIN_SECRET=change_me_to_a_strong_random_secret

# Data paths (relative to binary location)
GEOIP_CITY_DB=data/dbip.mmdb
GEOIP_ASN_DB=data/dbip-asn.mmdb
